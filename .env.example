# Copy this file to .env and fill in your own values.
# .env is gitignored so your credentials stay local.

# From apify.com -> Settings -> Integrations/API
APIFY_API_TOKEN=your-apify-token-here

# From console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# Path to your Google service-account JSON key file (see README.md)
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# The id from your spreadsheet's URL, between /d/ and /edit
GOOGLE_SHEET_ID=your-sheet-id-here
